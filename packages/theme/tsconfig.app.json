{
  "extends": "@vue/tsconfig",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vitepress/client"],
    "paths": {
      "#/*": ["./src/*", "./src/theme/*"]
    }
  },
  "vueCompilerOptions": {
    "vitePressExtensions": [".md"]
  },
  "include": ["src/*.ts", "src/theme/**/*"],
  "exclude": ["node_modules", "dist"]
}
