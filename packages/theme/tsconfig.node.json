{
  "extends": "@tsconfig/node24",
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "paths": {
      "#/*": ["./src/*", "./src/node/*"]
    }
  },
  "include": ["src/*.ts", "src/node/**/*"],
  "exclude": ["node_modules", "dist"]
}
