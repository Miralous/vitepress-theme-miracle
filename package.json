{
  "name": "@miracle/workspace",
  "version": "2.0.0",
  "private": true,
  "description": "A miraculously smooth VitePress theme",
  "keywords": [
    "blog",
    "blog-theme",
    "vitepress",
    "vitepress-theme"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "husky": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.0",
      "onFail": "download"
    }
  }
}
