{
  "extends": "@tsconfig/node24",
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": [".vitepress/**/*"],
  "exclude": [".vitepress/theme/**/*", "node_modules", "dist"]
}
